{
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "sourceMap": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "types": [
      "jquery",
      "vitest/globals"
    ],
    "lib": [
      "es2020",
      "dom"
    ],
    "rootDir": "./src",
    "outDir": "./lib"
  },
  "include": [
    "src/**/*.ts"
  ]
}